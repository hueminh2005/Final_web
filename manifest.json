{
    "name": "Note Management App",
    "short_name": "Notes",
    "description": "A feature-rich note management application with offline support",
    "start_url": "/index.php",
    "scope": "/",
    "display": "standalone",
    "orientation": "portrait-primary",
    "theme_color": "#007bff",
    "background_color": "#ffffff",
    "icons": [
        {
            "src": "/assets/images/icon-192.png",
            "sizes": "192x192",
            "type": "image/png",
            "purpose": "any"
        },
        {
            "src": "/assets/images/icon-512.png",
            "sizes": "512x512",
            "type": "image/png",
            "purpose": "any"
        },
        {
            "src": "/assets/images/icon-maskable.png",
            "sizes": "192x192",
            "type": "image/png",
            "purpose": "maskable"
        }
    ],
    "screenshots": [
        {
            "src": "/assets/images/screenshot-1.png",
            "sizes": "540x720",
            "type": "image/png",
            "form_factor": "narrow"
        },
        {
            "src": "/assets/images/screenshot-2.png",
            "sizes": "1280x720",
            "type": "image/png",
            "form_factor": "wide"
        }
    ],
    "categories": ["productivity"],
    "shortcuts": [
        {
            "name": "Create Note",
            "short_name": "New Note",
            "description": "Create a new note",
            "url": "/editor.php",
            "icons": [
                {
                    "src": "/assets/images/new-note.png",
                    "sizes": "192x192"
                }
            ]
        }
    ],
    "share_target": {
        "action": "/share",
        "method": "POST",
        "enctype": "multipart/form-data",
        "params": {
            "files": [
                {
                    "name": "media",
                    "accept": ["image/*", "text/*"]
                }
            ]
        }
    }
}
